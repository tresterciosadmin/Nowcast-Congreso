# Plantilla de variables de entorno — COPIÁ este archivo a .env y completá tus valores.
#   cp .env.example .env      (o copiá a mano en Windows)
# El .env real está en .gitignore: NO se commitea y NO se comparte. Cada persona pone SU key.
#
# Para conseguir una key: Claude Console -> Settings -> API keys -> Create Key.
# La key da acceso de facturación a la organización; conviene una key por persona
# (se revoca individual y se ve el uso por separado).

# API de Anthropic (obligatoria para correr el agente de taxonomías en vivo)
ANTHROPIC_API_KEY=sk-ant-REEMPLAZAR

# Modelo del clasificador (opcional; default en el código = claude-haiku-4-5).
# TAXO_MODEL=claude-haiku-4-5
