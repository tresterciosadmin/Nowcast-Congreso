# Datos (se regeneran con los scripts de ingesta; no se versionan)
**/data/raw/
**/data/clean/
*.parquet
*.csv
*.part
!**/.gitkeep

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.env
.ipynb_checkpoints/

# Outputs pesados / temporales
*.log
.DS_Store
Thumbs.db

# Node (skill docx build)
node_modules/
package-lock.json

# Conservar documentos del proyecto (docx/html/md) — NO ignorar
!*.docx
!*.html
!*.md

# Bases SQLite (binarios; no versionar) — datos/proyectos
*.db
*.sqlite
*.sqlite3

# Carpeta de descarte: ignorar contenido, conservar el README
Archivos_Borrar/*
!Archivos_Borrar/README.md
# Carpetas de descarte anidadas (ej. datos/Archivos_Borrar): mismo régimen
**/Archivos_Borrar/*
!**/Archivos_Borrar/README.md

# Padrón de bloques del Senado: CURADO A MANO, es fuente de verdad -> SÍ versionar
!datos/senado/data/padron_bloques_senado.csv
!datos/senado/data/padron_manual_2015_2017.csv

# TRANSITORIO (decisión Valle 2026-07-02): los entregables de disciplina y fichas SÍ se
# versionan mientras el sistema no esté en funcionamiento, para que el equipo los vea sin
# correr los scripts. Cuando esté operativo, revertir este bloque (volver a ignorarlos).
# El que regenere estos archivos debe commitearlos también, para no dejar versiones viejas.
!modelo/voto_individual/outputs/*.csv
!variables/legislador/data/legisladores.csv
!datos/export/data/*.xlsx

# Bot de recolección: su salida y su memoria SÍ se versionan (es la base viva
# que completa GitHub Actions; ver datos/bot_recoleccion/README.md)
!datos/bot_recoleccion/data/
!datos/bot_recoleccion/data/clean/
datos/bot_recoleccion/data/clean/*
!datos/bot_recoleccion/data/clean/dae_entradas.parquet
!datos/bot_recoleccion/data/estado_bot.json
!datos/bot_recoleccion/data/clean/tp_entradas.parquet

# datos/expedientes: salidas del backfill SÍ se versionan (régimen TRANSITORIO
# de Valle 02-07: los entregables viajan por git hasta que el sistema corra solo.
# Omisión del 11-07 corregida el 13-07: el equipo no veía los datos del embudo)
!datos/expedientes/data/
!datos/expedientes/data/clean/
datos/expedientes/data/clean/*
!datos/expedientes/data/clean/*.parquet
